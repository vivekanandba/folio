{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://folio.local/schemas/folio.pack.schema.json",
  "title": "FolioPack",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "subject",
    "type",
    "source",
    "summary",
    "tags",
    "curriculum"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "type": { "enum": ["magazine", "course", "book", "notes"] },
    "source": { "type": "string" },
    "summary": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "curriculum": {
      "type": "object",
      "required": ["concepts", "sessions"],
      "additionalProperties": false,
      "properties": {
        "sheet": { "type": "string" },
        "concepts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "sessions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    },
    "practiceNone": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
